<!--pages/test/test.wxml-->
<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="logo">
      <text class="icon">🎓</text>
      <text class="title">研值人格测试</text>
    </view>
    <text class="subtitle">Research Personality Test</text>
    <text class="description">基于真实研究生生活，61道趣味题目</text>
    <view class="disclaimer">
      <text>⚠️ 声明：本测试只是在玩梗，不是真的，请不要当真！</text>
    </view>
  </view>

  <!-- 进度条 -->
  <view class="progress-container">
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{progressPercent}}%"></view>
    </view>
    <text class="progress-text">进度: {{currentQuestion}}/{{totalQuestions}}</text>
  </view>

  <!-- 题目卡片 -->
  <view class="question-card" wx:if="{{!showResult}}">
    <view class="question-header">
      <text class="question-text">{{question}}</text>
      <view class="question-number">第 {{questionIndex}} 题</view>
    </view>
    
    <view class="options-container">
      <view 
        wx:for="{{options}}" 
        wx:key="index" 
        class="option {{currentAnswer === index ? 'selected' : ''}}"
        bindtap="selectOption"
        data-index="{{index}}"
      >
        {{item}}
      </view>
    </view>

    <view class="navigation">
      <button 
        class="btn btn-prev" 
        disabled="{{currentQuestion === 1}}"
        bindtap="prevQuestion"
      >
        <text class="icon">←</text> 上一题
      </button>
      <button 
        wx:if="{{!isLastQuestion}}"
        class="btn btn-next" 
        disabled="{{!hasAnswer}}"
        bindtap="nextQuestion"
      >
        下一题 <text class="icon">→</text>
      </button>
      <button 
        wx:else
        class="btn btn-submit" 
        disabled="{{!hasAnswer}}"
        bindtap="submitTest"
      >
        查看结果
      </button>
    </view>
  </view>

  <!-- 信息面板 -->
  <view class="info-panel" wx:if="{{!showResult}}">
    <view class="info-box">
      <view class="info-title">
        <text class="info-icon">💡</text>
        <text>测试说明</text>
      </view>
      <text class="info-text">本测试包含61道题目，答案选项为认同、中立、不认同。请根据你的真实感受选择，测试结果仅供娱乐。</text>
      <view class="info-disclaimer">
        <text>⚠️ 声明：本测试只是在玩梗，不是真的，请不要当真！</text>
      </view>
    </view>
    <view class="info-box">
      <view class="info-title">
        <text class="info-icon">🏷️</text>
        <text>可能的结果标签</text>
      </view>
      <view class="tags">
        <view class="tag" wx:for="{{resultTags}}" wx:key="index">{{item}}</view>
      </view>
    </view>
  </view>

  <!-- 结果展示 -->
  <view class="result-container" wx:if="{{showResult}}">
    <view class="result-card">
      <view class="result-type">{{result.type}}</view>
      <text class="result-description">{{result.description}}</text>
      
      <view class="result-disclaimer">
        <text>⚠️ 声明：本测试只是在玩梗，不是真的，请不要当真！</text>
      </view>
      
      <view class="result-details">
        <view class="detail-title">
          <text class="detail-icon">📊</text>
          <text>维度分析</text>
        </view>
        <view class="dimensions">
          <view class="dimension">
            <text class="dim-label">学术力</text>
            <view class="dim-bar">
              <view class="dim-fill" style="width: {{result.academicPower}}%"></view>
            </view>
            <text class="dim-value">{{result.academicPower}}%</text>
          </view>
          <view class="dimension">
            <text class="dim-label">抗压力</text>
            <view class="dim-bar">
              <view class="dim-fill" style="width: {{result.stressResistance}}%"></view>
            </view>
            <text class="dim-value">{{result.stressResistance}}%</text>
          </view>
          <view class="dimension">
            <text class="dim-label">玩梗力</text>
            <view class="dim-bar">
              <view class="dim-fill" style="width: {{result.memeSkill}}%"></view>
            </view>
            <text class="dim-value">{{result.memeSkill}}%</text>
          </view>
        </view>
      </view>
      
      <view class="share-section">
        <view class="share-title">
          <text class="share-icon">🔗</text>
          <text>分享结果</text>
        </view>
        <button 
          class="share-btn" 
          open-type="share"
          hover-class="btn-hover"
        >
          分享给朋友
        </button>
      </view>
      
      <button 
        class="btn btn-retake" 
        bindtap="retakeTest"
      >
        重新测试
      </button>
    </view>
  </view>

  <!-- 页脚 -->
  <view class="footer" wx:if="{{!showResult}}">
    <text class="footer-text">本测试基于真实研究生生活设计，仅供娱乐使用。</text>
  </view>
</view>